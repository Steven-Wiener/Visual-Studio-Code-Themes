{
	"$schema": "vscode://schemas/color-theme",
	"type": "dark",
	"colors": {
		"editor.background": "#0b2925",
		"editorCursor.foreground": "#DBDBDB",
		"editor.foreground": "#F0F6FF",
		"editorWhitespace.foreground": "#BFBFBF",
		"editor.lineHighlightBackground": "#242424",
		"editor.selectionBackground": "#395B6E",
		"sideBar.background": "#113d37"
	},
	"tokenColors": [
		{
			"settings": {
				"foreground": "#F0F6FF",
			}
		},
		{
			"name": "Comment",
			"scope": "comment",
			"settings": {
				"fontStyle": "",
				"foreground": "#B6C6D4"
			}
		},
		{
			"name": "String",
			"scope": "string",
			"settings": {
				"fontStyle": "",
				"foreground": "#F0F07A"
			}
		},
		{
			"name": "Number",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#7BD827"
			}
		},
		{
			"name": "Built-in constant",
			"scope": "constant.language",
			"settings": {
				"fontStyle": "",
				"foreground": "#FFAA00"
			}
		},
		{
			"name": "User-defined constant",
			"scope": [
				"constant.character",
				"constant.other"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Variable",
			"scope": [
				"variable.language",
				"variable.other"
			],
			"settings": {
				"foreground": "#53B7ED"
			}
		},
		{
			"name": "Keyword",
			"scope": "keyword",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#febe5a"
			}
		},
		{
			"name": "Storage",
			"scope": "storage",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#A3D295"
			}
		},
		{
			"name": "Class name",
			"scope": "entity.name.class",
			"settings": {
				"fontStyle": ""
			}
		},
		{
			"name": "Inherited class",
			"scope": "entity.other.inherited-class",
			"settings": {
				"fontStyle": ""
			}
		},
		{
			"name": "Tag name",
			"scope": "entity.name.tag",
			"settings": {
				"fontStyle": "",
				"foreground": "#7BD827"
			}
		},
		{
			"name": "function name",
			"scope": "entity.name.function",
			"settings": {
				"foreground": "#ffffff",
				"fontStyle": ""
			}
		},
		{
			"name": "Tag attribute",
			"scope": "entity.other.attribute-name",
			"settings": {
				"fontStyle": "",
				"foreground": "#708E67"
			}
		},
		{
			"name": "Library function",
			"scope": "support.function",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Library function call",
			"scope": "meta.function-call",
			"settings": {
				"fontStyle": "",
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Library function call object",
			"scope": "meta.function-call.object",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#ececec"
			}
		},
		{
			"name": "Library constant",
			"scope": "support.constant",
			"settings": {
				"fontStyle": ""
			}
		},
		{
			"name": "Library class/type",
			"scope": [
				"support.type",
				"support.class"
			],
			"settings": {
				"fontStyle": ""
			}
		},
		{
			"name": "Library variable",
			"scope": "support.other.variable",
			"settings": {
				"fontStyle": ""
			}
		},
		{
			"name": "Storage type",
			"scope": "storage.type",
			"settings": {
				"foreground": "#73FF8C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Invalid",
			"scope": "invalid",
			"settings": {
				"fontStyle": "",
				"foreground": "#FF0000"
			}
		},
		{
			"name": "Illegal comment block",
			"scope": "invalid.illegal.missing-asterisk.phpdoc",
			"settings": {
				"foreground": "#FFC1A8",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Invalid - Deprecated",
			"scope": "invalid.deprecated",
			"settings": {
				"fontStyle": "italic underline"
			}
		},
		{
			"name": "Invalid - Illegal",
			"scope": "invalid.illegal",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#F9CFCE"
			}
		},
		{
			"name": "CSS: Selectors",
			"scope": [
				"meta.selector",
				"meta.selector entity",
				"meta.selector entity punctuation",
				"entity.name.tag.css"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#00B7FF"
			}
		},
		{
			"name": "CSS: Property Names",
			"scope": [
				"meta.property-name",
				"support.type.property-name"
			],
			"settings": {
				"foreground": "#F0F6FA"
			}
		},
		{
			"name": "CSS: Property Values",
			"scope": [
				"meta.property-value constant.numeric",
				"meta.property-value constant",
				"meta.property-value keyword"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#7BD827"
			}
		},
		{
			"name": "CSS: Name Tag",
			"scope": "meta.selector entity.name.tag.css",
			"settings": {
				"fontStyle": "",
				"foreground": "#9CEFFF"
			}
		},
		{
			"name": "CSS: Class ID",
			"scope": [
				"meta.selector entity.other.attribute-name.class.css",
				"entity.other.attribute-name.id.css"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#53B7ED"
			}
		},
		{
			"name": "CSS: Pseudo Class",
			"scope": "entity.other.attribute-name.pseudo-class",
			"settings": {
				"fontStyle": "",
				"foreground": "#73FF8C"
			}
		},
		{
			"name": "CSS: Constant property value",
			"scope": "support.constant.property-value",
			"settings": {
				"fontStyle": "",
				"foreground": "#9CFFCD"
			}
		},
		{
			"name": "CSS: Constant other",
			"scope": "constant.other",
			"settings": {
				"fontStyle": "",
				"foreground": "#7BD827"
			}
		},
		{
			"name": "CSS: Keyword other unit",
			"scope": "keyword.other.unit",
			"settings": {
				"fontStyle": "",
				"foreground": "#7BD827"
			}
		},
		{
			"name": "CSS: Support function misc",
			"scope": "support.function.misc",
			"settings": {
				"fontStyle": "bold",
				"foreground": "#FFA3D3"
			}
		},
		{
			"name": "CSS: Meta selector",
			"scope": "meta.selector.css",
			"settings": {
				"fontStyle": "",
				"foreground": "#ffffff"
			}
		},
		{
			"name": "HTML: Doctype Declaration",
			"scope": "meta.tag.sgml.doctype",
			"settings": {
				"fontStyle": "",
				"foreground": "#ffffff"
			}
		},
		{
			"name": "HTML: Tags",
			"scope": "entity.name.tag",
			"settings": {
				"fontStyle": "",
				"foreground": "#7BD827"
			}
		},
		{
			"name": "HTML: Attribute Punctuation",
			"scope": "meta.tag string punctuation",
			"settings": {
				"fontStyle": "",
				"foreground": "#ffffff"
			}
		},
		{
			"name": "HTML: Tag Punctuation",
			"scope": "punctuation.definition.tag",
			"settings": {
				"fontStyle": "",
				"foreground": "#7BD827"
			}
		},
		{
			"name": "HTML: Entities",
			"scope": "constant.character.entity",
			"settings": {
				"fontStyle": "",
				"foreground": "#53B7ED"
			}
		},
		{
			"name": "HTML: Attribute Names",
			"scope": "entity.other.attribute-name",
			"settings": {
				"fontStyle": "",
				"foreground": "#53B7ED"
			}
		},
		{
			"name": "HTML: Attribute Values",
			"scope": [
				"meta.tag string.quoted",
				"meta.tag string.quoted constant.character.entity"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#F0F07A"
			}
		},
		{
			"name": "HTML: Punctuation Definition Comment",
			"scope": [
				"comment.block.html",
				"punctuation.definition.commment.html"
			],
			"settings": {
				"fontStyle": "",
				"foreground": "#ACE2F2"
			}
		}
	]
}