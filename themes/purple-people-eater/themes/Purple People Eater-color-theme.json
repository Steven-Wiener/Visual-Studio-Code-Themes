  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#65375a",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#b700ff"
      }
    },
    {
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c533ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#76ee00"
      }
    },
    {
      "scope": [
        "entity.name.method.js"
      ],
      "settings": {
        "foreground": "#8aff18",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#f5d300"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#ffe129"
      }
    },
    {
      "scope": [
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#c2a700"
      }
    },
    {
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#08f7fe"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#31f8fe",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#a500e6",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#f5d300",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#ff0077"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#08f7fe"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#ff0077"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#76ee00"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#08f7fe"
      }
    },
    {
      "scope": [
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#08f7fe",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#fe20a7"
      }
    },
    {
      "scope": "source.json meta.structure.dictionary.json support.type.property-name.json",
      "settings": {
        "foreground": "#f5d300"
      }
    },
    {
      "scope": "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
      "settings": {
        "foreground": "#08f7fe"
      }
    },
    {
      "scope": "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
      "settings": {
        "foreground": "#76ee00"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#b700ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#b700ff",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#c533ff",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#76ee00",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#76ee00"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#ff5370"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#ffee22"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff5370"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#08f7fe"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#cd9731"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#f44747"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#f5d300"
      }
    }
  ]
}