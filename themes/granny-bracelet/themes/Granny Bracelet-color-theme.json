  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7b7b7b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#c32750"
      }
    },
    {
      "scope": [
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d9446b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": [
        "entity.name.method.js"
      ],
      "settings": {
        "foreground": "#0eb0e1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "constant.other.symbol",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#c49822"
      }
    },
    {
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#ddb13c"
      }
    },
    {
      "scope": [
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#99761a"
      }
    },
    {
      "scope": [
        "variable",
        "string constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#0eb0e1",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#ae2347",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "keyword.other.unit"
      ],
      "settings": {
        "foreground": "#603bd9",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#c32750"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#c32750"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class"
      ],
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": [
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#0C92BB",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#c8c8c8"
      }
    },
    {
      "scope": "source.json meta.structure.dictionary.json support.type.property-name.json",
      "settings": {
        "foreground": "#c49822"
      }
    },
    {
      "scope": "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": "source.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json meta.structure.dictionary.value.json meta.structure.dictionary.json support.type.property-name.json",
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#3fdf64",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#c32750",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#d9446b",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#0C92BB",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#76ee00"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#ff5370"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#ffee22"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff5370"
      }
    },
    {
      "scope": "token.info-token",
      "settings": {
        "foreground": "#0C92BB"
      }
    },
    {
      "scope": "token.warn-token",
      "settings": {
        "foreground": "#cd9731"
      }
    },
    {
      "scope": "token.error-token",
      "settings": {
        "foreground": "#f44747"
      }
    },
    {
      "scope": "token.debug-token",
      "settings": {
        "foreground": "#603bd9"
      }
    }
  ]
}